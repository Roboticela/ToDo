# Backend API URL (used for auth, tasks, Paddle, etc.)
# Set to your server BACKEND_URL so the frontend redirects and requests go to the right host.
# Examples: http://localhost:3000  or  https://api.todo.roboticela.com
#
# For production Docker build, pass at build time (Vite bakes this in at build time):
#   docker build --build-arg VITE_API_URL=https://api.todo.roboticela.com .
VITE_API_URL=http://localhost:3000
