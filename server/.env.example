# Database
DATABASE_URL="postgresql://user:password@localhost:5432/todo?schema=public"

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend URLs (for redirects and CORS)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
# Custom protocol for desktop app OAuth callback
APP_DEEP_LINK_SCHEME=roboticela-todo

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Redirect URIs to register in Google Console:
# - Web: FRONTEND_URL/auth/callback (handled by SPA) or backend callback then redirect
# - We use backend callback then redirect to frontend

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Roboticela ToDo <noreply@todo.roboticela.com>"

# Email: verification, reminders, unsubscribe
SUBSCRIPTION_REMINDER_INTERVAL_DAYS=7
EMAIL_UNSUBSCRIBE_SECRET=your-unsubscribe-secret-min-32-chars

# Paddle Billing (https://developer.paddle.com/)
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
# Price IDs from Paddle catalog (subscription prices)
PADDLE_PRICE_ID_BASIC=pri_xxxx
PADDLE_PRICE_ID_PRO=pri_xxxx

# Cloudflare R2 (avatar storage; optional – avatars fall back to URL or none if unset)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=your-bucket-name
# Public base URL for bucket (e.g. https://pub-xxx.r2.dev/your-bucket or custom domain)
R2_PUBLIC_URL=https://your-bucket.example.com

# Server
PORT=3000
NODE_ENV=development
